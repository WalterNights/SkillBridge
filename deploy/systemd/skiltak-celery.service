[Unit]
Description=SkilTak Celery worker
After=network.target redis-server.service

[Service]
Type=simple
User=skiltak
Group=www-data
WorkingDirectory=/var/www/skiltak/backend
EnvironmentFile=/var/www/skiltak/.env
ExecStart=/var/www/skiltak/venv/bin/celery -A core worker --loglevel=info --concurrency=2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
