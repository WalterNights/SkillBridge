# =============================================================================
# SkilTak - Variables de entorno (ejemplo)
# =============================================================================
# Copialo a `.env` en el mismo directorio (root del proyecto) y rellena valores.
# El archivo `.env` está gitignored y NUNCA debe commitearse.
#
# Lo consumen:
#   - Backend (Django) via python-decouple, leyendo `BASE_DIR.parent / .env`
#   - Frontend (Angular) via `frontend/scripts/build-env.js`, que genera
#     `frontend/src/environment/environment.prod.ts` antes del `ng build`.
# =============================================================================


# ----- Entorno -----
# development | staging | production
ENVIRONMENT=development


# ----- Django -----
# Generar uno nuevo para prod: `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=cambiar-en-prod-generar-uno-seguro
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1


# ----- Base de datos -----
# Dev (SQLite):
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=database/db.sqlite3
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# Prod (PostgreSQL):
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=skiltak_db
# DATABASE_USER=skiltak_user
# DATABASE_PASSWORD=
# DATABASE_HOST=localhost
# DATABASE_PORT=5432


# ----- CORS -----
# Lista separada por comas. En prod incluí los orígenes HTTPS exactos.
CORS_ALLOWED_ORIGINS=http://localhost:4200


# ----- Celery + Redis -----
# En prod usamos DBs separadas (2 y 3) para no chocar con otros proyectos del VPS.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1


# ----- Email (SMTP) -----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@skiltak.com


# ----- Análisis de CV (proveedor IA) -----
# Proveedor del adapter `CVAnalyzer`. Hoy solo `gemini`.
# Cambiar a `claude` o `openai` cuando se implementen sus adapters.
CV_ANALYZER_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
# Modelo de Gemini. Default: gemini-2.5-flash (estable, free tier, thinking).
# Otras: gemini-2.5-pro (más capable), gemini-flash-latest (alias siempre al último Flash).
GEMINI_MODEL=gemini-2.5-flash

# ----- Servicios externos -----
STITCH_API_KEY=


# ----- LinkedIn OAuth (Sign In with LinkedIn / OpenID Connect) -----
# App registrada en https://www.linkedin.com/developers/apps
# Producto requerido: "Sign In with LinkedIn using OpenID Connect" (instant-approve).
# El REDIRECT_URI tiene que matchear BYTE-EXACT lo registrado en LinkedIn:
# incluido http vs https, slash final, puerto.
#
# Si los 3 valores están vacíos, los endpoints /api/auth/linkedin/* devuelven
# 503 con mensaje claro — el botón del frontend igual existe pero al click
# da error explicativo en vez de un 500 críptico.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Dev:
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback/
LINKEDIN_FRONTEND_COMPLETE_URL=http://localhost:4200/auth/linkedin/complete
# Prod:
# LINKEDIN_REDIRECT_URI=https://api.skiltak.com/api/auth/linkedin/callback/
# LINKEDIN_FRONTEND_COMPLETE_URL=https://skiltak.com/auth/linkedin/complete


# ----- Frontend (Angular) -----
# URL pública del backend, sin slash al final.
# Dev:  http://localhost:8000/api
# Prod: https://api.skiltak.com/api
FRONTEND_API_URL=http://localhost:8000/api
