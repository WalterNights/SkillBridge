<?xml version="1.0" encoding="UTF-8"?>
<!--
  SkilTak — sitemap.xml
  Solo incluimos rutas públicas (sin auth). Las protegidas (/dashboard,
  /me, /cv, etc.) no aportan al SEO y disparan redirects, así que
  quedan fuera. Cuando agreguemos blog/recursos, sumar sus URLs acá.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://skiltak.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://skiltak.com/auth/register</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://skiltak.com/auth/login</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://skiltak.com/auth/forgot-password</loc>
    <changefreq>yearly</changefreq>
    <priority>0.2</priority>
  </url>
</urlset>
